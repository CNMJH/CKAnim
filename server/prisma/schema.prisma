generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  email     String   @unique
  role      String   @default("editor")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model Game {
  id          Int            @id @default(autoincrement())
  name        String         @unique
  description String?
  icon        String?
  iconUrl     String?
  order       Int            @default(0)
  published   Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  characters  Character[]
  categories  GameCategory[]
  videos      Video[]

  @@map("games")
}

model GameCategory {
  id         Int            @id @default(autoincrement())
  name       String
  icon       String?
  iconUrl    String?
  level      Int
  order      Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  parentId   Int?
  gameId     Int?
  characters Character[]
  game       Game?          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  parent     GameCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children   GameCategory[] @relation("CategoryHierarchy")
  videos     Video[]        @relation("VideoCategories")

  @@index([gameId])
  @@index([parentId])
  @@map("game_categories")
}

model VideoTag {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  VideoTags VideoTags[]

  @@map("video_tags")
}

model Video {
  id           Int            @id @default(autoincrement())
  title        String
  description  String?
  duration     Int?
  thumbnail    String?
  coverUrl     String?
  order        Int            @default(0)
  published    Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  qiniuKey     String
  qiniuUrl     String
  gameId       Int
  actionId     Int?           @unique
  coverUrlJpg  String?
  coverUrlWebp String?
  VideoTags    VideoTags[]
  favorites    Favorite[]
  action       Action?        @relation(fields: [actionId], references: [id], onDelete: Cascade)
  game         Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  categories   GameCategory[] @relation("VideoCategories")

  @@index([gameId])
  @@index([actionId])
  @@map("videos")
}

model Character {
  id          Int           @id @default(autoincrement())
  name        String
  avatar      String?
  description String?
  gameId      Int
  order       Int           @default(0)
  published   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  categoryId  Int?
  actions     Action[]
  category    GameCategory? @relation(fields: [categoryId], references: [id])
  game        Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, name])
  @@index([gameId])
  @@index([categoryId])
  @@map("characters")
}

model Action {
  id          Int       @id @default(autoincrement())
  name        String
  code        String
  description String?
  order       Int       @default(0)
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  characterId Int
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  video       Video?

  @@index([characterId])
  @@map("actions")
}

model SiteSettings {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("site_settings")
}

model VideoTags {
  A          Int
  B          Int
  video_tags VideoTag @relation(fields: [B], references: [id], onDelete: Cascade)
  videos     Video    @relation(fields: [A], references: [id], onDelete: Cascade)

  @@unique([A, B], map: "_VideoTags_AB_unique")
  @@index([B], map: "_VideoTags_B_index")
  @@map("_VideoTags")
}

model User {
  id                  Int                    @id @default(autoincrement())
  username            String                 @unique
  email               String                 @unique
  password            String
  avatar              String?
  avatarStatus        String                 @default("pending")
  avatarRejectReason  String?
  phone               String?
  role                String                 @default("user")
  vipLevel            String                 @default("none")
  vipExpires          DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  favoriteCollections FavoriteCollection[]
  favorites           Favorite[]
  libraryActions      UserLibraryAction[]
  libraryCategories   UserLibraryCategory[]
  libraryCharacters   UserLibraryCharacter[]
  libraryVideos       UserLibraryVideo[]
  lotteryRecords      LotteryRecord[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model VipPlan {
  id            Int      @id @default(autoincrement())
  name          String
  level         String
  price         String
  originalPrice String?
  features      String
  badge         String?
  order         Int      @default(0)
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([level])
  @@index([enabled])
  @@map("vip_plans")
}

model FavoriteCollection {
  id          Int        @id @default(autoincrement())
  userId      Int
  name        String
  description String?
  isDefault   Boolean    @default(false)
  cover       String?
  count       Int        @default(0)
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites   Favorite[]

  @@index([userId])
  @@map("favorite_collections")
}

model Favorite {
  id           Int                @id @default(autoincrement())
  userId       Int
  videoId      Int
  collectionId Int
  createdAt    DateTime           @default(now())
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  video        Video              @relation(fields: [videoId], references: [id], onDelete: Cascade)
  collection   FavoriteCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId, collectionId])
  @@index([userId])
  @@index([videoId])
  @@index([collectionId])
  @@map("favorites")
}

model Carousel {
  id        Int      @id @default(autoincrement())
  title     String
  imageUrl  String
  targetUrl String?
  order     Int      @default(0)
  duration  Int      @default(24)
  startTime DateTime
  endTime   DateTime
  active    Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([endTime])
  @@map("carousels")
}

model UserLibraryCategory {
  id         Int                    @id @default(autoincrement())
  userId     Int
  name       String
  icon       String?
  iconUrl    String?
  order      Int                    @default(0)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  characters UserLibraryCharacter[]

  @@index([userId])
  @@map("user_library_categories")
}

model UserLibraryCharacter {
  id          Int                  @id @default(autoincrement())
  userId      Int
  name        String
  avatar      String?
  description String?
  categoryId  Int?
  order       Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  actions     UserLibraryAction[]
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    UserLibraryCategory? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@index([categoryId])
  @@map("user_library_characters")
}

model UserLibraryAction {
  id          Int                  @id @default(autoincrement())
  userId      Int
  name        String
  code        String?
  description String?
  order       Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  characterId Int
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  character   UserLibraryCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  video       UserLibraryVideo?

  @@index([userId])
  @@index([characterId])
  @@map("user_library_actions")
}

model UserLibraryVideo {
  id          Int                @id @default(autoincrement())
  userId      Int
  title       String
  description String?
  duration    Int?
  coverUrl    String?
  qiniuKey    String
  qiniuUrl    String
  fileSize    Int                @default(0)
  actionId    Int?               @unique
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      UserLibraryAction? @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([actionId])
  @@map("user_library_videos")
}

model UserLibrarySettings {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("user_library_settings")
}

model UserLibraryLevel {
  id              Int      @id @default(autoincrement())
  vipLevel        String   @unique  // vip0, vip_monthly, vip_yearly, vip_lifetime
  name            String   // 等级名称
  maxStorage      Int      @default(0)  // 最大存储容量 (MB)
  maxFileSize     Int      @default(0)  // 单个文件最大大小 (MB)
  maxDailyUploads Int      @default(0)  // 每日最大上传次数
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([vipLevel])
  @@map("user_library_levels")
}

model LotteryConfig {
  id          Int              @id @default(autoincrement())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  dailyLimit  Int              @default(1)
  totalBudget Int?
  enabled     Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  prizes      LotteryPrize[]
  records     LotteryRecord[]

  @@index([enabled])
  @@map("lottery_configs")
}

model LotteryPrize {
  id            Int            @id @default(autoincrement())
  configId      Int
  name          String
  type          String         // points, item, physical
  value         Int
  displayName   String
  description   String?
  image         String?
  probability   Float          @default(0)
  totalStock    Int?
  remainingStock Int?
  enabled       Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  config        LotteryConfig  @relation(fields: [configId], references: [id], onDelete: Cascade)
  records       LotteryRecord[]

  @@index([configId])
  @@map("lottery_prizes")
}

model LotteryRecord {
  id         Int           @id @default(autoincrement())
  userId     Int
  configId   Int
  prizeId    Int?
  prizeType  String?       // points, item, physical
  prizeName  String?
  prizeValue Int?
  drawDate   DateTime
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  config     LotteryConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  prize      LotteryPrize? @relation(fields: [prizeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([configId])
  @@index([drawDate])
  @@map("lottery_records")
}
