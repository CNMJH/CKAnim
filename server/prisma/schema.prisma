// CKAnim 数据库 Schema
// 层级关系：游戏 > 分类 > 角色 > 动作 > 视频

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ===== 管理员表 =====
model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  email     String   @unique
  role      String   @default("editor")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

// ===== 游戏表（最父级）=====
model Game {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  icon        String?
  iconUrl     String?
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 子级关联
  categories GameCategory[] // 游戏分类
  videos     Video[] // 游戏视频
  characters Character[] // 游戏角色

  @@map("games")
}

// ===== 游戏分类表（游戏的子级，用于角色分类）=====
model GameCategory {
  id        Int      @id @default(autoincrement())
  name      String
  icon      String?
  iconUrl   String?
  level     Int
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 自关联（支持多级分类）
  parentId Int?
  parent   GameCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children GameCategory[] @relation("CategoryHierarchy")

  // 关联到游戏
  gameId Int?
  game   Game? @relation(fields: [gameId], references: [id], onDelete: Cascade)

  // 关联到视频（用于视频分类筛选）
  videos Video[] @relation("VideoCategories")

  // 关联到角色（角色分类）
  characters Character[]

  @@index([gameId])
  @@index([parentId])
  @@map("game_categories")
}

// ===== 视频标签表（独立表，用于视频搜索）=====
model VideoTag {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  videos Video[] @relation("VideoTags")

  @@map("video_tags")
}

// ===== 视频表（存储视频文件）=====
model Video {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  duration    Int?
  thumbnail   String?
  coverUrl    String?
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  qiniuKey String
  qiniuUrl String

  // 关联到游戏
  gameId Int
  game   Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  // 关联到分类（用于筛选）
  categories GameCategory[] @relation("VideoCategories")

  // 关联到标签（用于搜索）
  tags VideoTag[] @relation("VideoTags")

  // 关联到动作（视频属于动作，1 对 1 关系）
  actionId Int?     @unique
  action   Action? @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([actionId])
  @@map("videos")
}

// ===== 角色表（分类的子级，用户选择想看的角色）=====
model Character {
  id          Int      @id @default(autoincrement())
  name        String
  avatar      String?
  description String?
  gameId      Int
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联到游戏
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  // 关联到动作（动作直接属于角色）
  actions Action[]

  // 关联到分类（角色分类）
  categoryId Int?
  category   GameCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([gameId, name])
  @@index([gameId])
  @@index([categoryId])
  @@map("characters")
}

// ===== 动作表（直接属于角色，1 对 1 视频关联）=====
model Action {
  id          Int      @id @default(autoincrement())
  name        String
  code        String // 动作代码：attack/walk/skill 等
  description String?
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联到角色（动作直接属于角色）
  characterId Int
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  // 关联到视频（1 对 1 关系）
  video Video?

  @@index([characterId])
  @@map("actions")
}

// ===== 网站设置表（存储网站自定义配置）=====
model SiteSettings {
  id          Int      @id @default(autoincrement())
  key         String   @unique // 设置键名
  value       String   // 设置值（JSON 字符串）
  description String?  // 设置描述
  updatedAt   DateTime @updatedAt

  @@map("site_settings")
}
