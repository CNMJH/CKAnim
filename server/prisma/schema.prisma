generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  email     String   @unique
  role      String   @default("editor")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model Game {
  id          Int            @id @default(autoincrement())
  name        String         @unique
  description String?
  icon        String?
  iconUrl     String?
  order       Int            @default(0)
  published   Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  characters  Character[]
  categories  GameCategory[]
  videos      Video[]

  @@map("games")
}

model GameCategory {
  id         Int            @id @default(autoincrement())
  name       String
  icon       String?
  iconUrl    String?
  level      Int
  order      Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  parentId   Int?
  gameId     Int?
  characters Character[]
  game       Game?          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  parent     GameCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children   GameCategory[] @relation("CategoryHierarchy")
  videos     Video[]        @relation("VideoCategories")

  @@index([gameId])
  @@index([parentId])
  @@map("game_categories")
}

model VideoTag {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  VideoTags VideoTags[]

  @@map("video_tags")
}

model Video {
  id          Int            @id @default(autoincrement())
  title       String
  description String?
  duration    Int?
  thumbnail   String?
  coverUrl    String?
  order       Int            @default(0)
  published   Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  qiniuKey    String
  qiniuUrl    String
  gameId      Int
  actionId    Int?           @unique
  VideoTags   VideoTags[]
  action      Action?        @relation(fields: [actionId], references: [id], onDelete: Cascade)
  game        Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  categories  GameCategory[] @relation("VideoCategories")

  @@index([gameId])
  @@index([actionId])
  @@map("videos")
}

model Character {
  id          Int           @id @default(autoincrement())
  name        String
  avatar      String?
  description String?
  gameId      Int
  order       Int           @default(0)
  published   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  categoryId  Int?
  actions     Action[]
  category    GameCategory? @relation(fields: [categoryId], references: [id])
  game        Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, name])
  @@index([gameId])
  @@index([categoryId])
  @@map("characters")
}

model Action {
  id          Int       @id @default(autoincrement())
  name        String
  code        String
  description String?
  order       Int       @default(0)
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  characterId Int
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  video       Video?

  @@index([characterId])
  @@map("actions")
}

model SiteSettings {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("site_settings")
}

model VideoTags {
  A          Int
  B          Int
  video_tags VideoTag @relation(fields: [B], references: [id], onDelete: Cascade)
  videos     Video    @relation(fields: [A], references: [id], onDelete: Cascade)

  @@unique([A, B], map: "_VideoTags_AB_unique")
  @@index([B], map: "_VideoTags_B_index")
  @@map("_VideoTags")
}
