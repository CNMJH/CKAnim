// 这是你的 Prisma schema 文件
// 使用 SQLite 进行快速开发和测试

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 管理员表
model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  email     String   @unique
  role      String   @default("editor")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

// 游戏表
model Game {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  icon        String?  // 本地图标路径（保留兼容）
  iconUrl     String?  // 七牛云图标 URL（新增）
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories GameCategory[]
  videos     Video[]
  characters Character[]

  @@map("games")
}

// 游戏分类表（支持 1-7 级分类）
model GameCategory {
  id        Int      @id @default(autoincrement())
  name      String
  icon      String?  // 本地图标路径（保留兼容）
  iconUrl   String?  // 七牛云图标 URL（新增）
  level     Int
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parentId  Int?
  parent    GameCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  GameCategory[] @relation("CategoryHierarchy")

  gameId  Int?
  game    Game? @relation(fields: [gameId], references: [id], onDelete: Cascade)

  videos  Video[] @relation("VideoCategories")

  @@index([gameId])
  @@index([parentId])
  @@map("game_categories")
}

// 视频标签表（仅管理员后台使用，前台不展示）
model VideoTag {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  videos  Video[] @relation("VideoTags")

  @@map("video_tags")
}

// 视频表
model Video {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  duration    Int?
  thumbnail   String?  // 本地缩略图路径（保留兼容）
  coverUrl    String?  // 七牛云封面图 URL（新增）
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  qiniuKey  String
  qiniuUrl  String

  gameId  Int
  game    Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  categories GameCategory[] @relation("VideoCategories")
  tags       VideoTag[]     @relation("VideoTags")
  
  // 角色动作关联（新增）
  characterActions CharacterAction[]

  @@index([gameId])
  @@map("videos")
}

// 角色表（新增）
model Character {
  id          Int      @id @default(autoincrement())
  name        String
  role        String?  // 职业：战士/法师/刺客等
  avatar      String?  // 角色头像 URL
  description String?
  gameId      Int
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  game    Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  actions CharacterAction[]

  @@unique([gameId, name])
  @@index([gameId])
  @@map("characters")
}

// 动作表（新增）
model Action {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   // 动作代码：attack/walk/skill 等
  description String?
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  characters CharacterAction[]

  @@map("actions")
}

// 角色 - 动作关联表（新增）
model CharacterAction {
  id          Int      @id @default(autoincrement())
  characterId Int
  actionId    Int
  videoId     Int?     // 关联的视频 ID（可选）
  videoUrl    String?  // 直接存储视频 URL（可选）
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  action    Action    @relation(fields: [actionId], references: [id], onDelete: Cascade)
  video     Video?    @relation(fields: [videoId], references: [id])

  @@unique([characterId, actionId])
  @@index([characterId])
  @@index([actionId])
  @@map("character_actions")
}
